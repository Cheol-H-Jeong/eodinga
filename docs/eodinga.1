.SH EXAMPLES
.nf
eodinga index \-\-root ~/projects \-\-root ~/docs
eodinga search 'date:this\-week ext:md roadmap' \-\-limit 20
eodinga search 'regex:/todo|fixme/i path:src' \-\-json
eodinga stats \-\-json
eodinga doctor
.fi
.SH FILES
Linux config: ~/.config/eodinga/config.toml
.br
Linux index: ~/.local/share/eodinga/index.db
.br
Windows config: %APPDATA%\\eodinga\\config.toml
.br
Windows index: %LOCALAPPDATA%\\eodinga\\index.db
